{
    "compilerOptions": {
        "target": "ES2018",
        "lib": ["ES2018", "DOM"],
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "dist"
    },
    "include": ["*.ts", "*.tsx"],
    "exclude": ["node_modules", "dist"]
}
